# Credenciais da service account do Google Analytics (para scripts locais e testes).
# No Worker da Cloudflare, configure as mesmas variaveis via: npx wrangler secret put <NOME>
GA_SERVICE_ACCOUNT_EMAIL=nome@projeto.iam.gserviceaccount.com
GA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GA_PRIVATE_KEY_ID=
GA_CLIENT_ID=

# Property principal do site (LPs/BIO usa 503617174, fixo no codigo)
GA_PROPERTY_ID=483869089

# Frontend local: URL do Worker (dev: http://localhost:8787)
VITE_API_URL=http://localhost:8787
